  Query 3 - Clear, paste, Run:
  SELECT u.name, u.email, COUNT(tc.id) as completions
  FROM "User" u
  LEFT JOIN "TaskCompletion" tc ON u.id = tc."userId"
  GROUP BY u.id, u.name, u.email ORDER BY completions DESC;

  Query 4 - Clear, paste, Run:
  SELECT DISTINCT u.name, u.email
  FROM "User" u
  JOIN "TaskCompletion" tc ON u.id = tc."userId"
  WHERE tc."completedAt" >= NOW() - INTERVAL '7 days';

  Query 5 - Clear, paste, Run:
  SELECT u.name, u.email,
    (SELECT COUNT(*) FROM "Task" t WHERE t."userId" = u.id) as tasks,
    (SELECT COUNT(*) FROM "TaskCompletion" tc WHERE tc."userId" = u.id) as completions,
    (SELECT COUNT(*) FROM "TaskPhoto" tp WHERE tp."userId" = u.id) as photos
  FROM "User" u;


